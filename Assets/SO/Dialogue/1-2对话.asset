    resumeEvent: 
  - speaker: {fileID: 11400000, guid: 5a647ed4a73833542a667c930590a7e0, type: 2}
    text: "\u8BF7...\u8BF7\u4E0D\u7528\u5728\u610F\u53EF\u7433...\u83B1\u5361\u6069\u5148\u751F\u8BF4\u8FD9\u6B21\u662F\u7279\u6B8A\u59D4\u6258\uFF0C\u4E0D\u80FD\u548C\u5176\u4ED6\u4EBA\u900F\u9732\u592A\u591A\uFF08\u5938\u5F20\u7684\u53CD\u590D\u97A0\u8EAC\u52A0\u53CD\u590D\u9053\u6B49\uFF09"
