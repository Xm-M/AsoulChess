  - speaker: {fileID: 11400000, guid: 1625cc78642a5d641bf088ce6713c325, type: 2}
    text: "\u8001\u59D0\u4F60\u5728\u8DDF\u8C01\u8BF4\u8BDD\uFF1F\u800C\u4E14\u6CA1\u6709\u4EBA\u5728\u610F\u4E00\u4E0B\u7AD9\u5728\u95E8\u53E3\u7684...\u5973\u4EC6\u5C0F\u59D0\u5417\uFF1F"
