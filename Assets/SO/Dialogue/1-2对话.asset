  - speaker: {fileID: 11400000, guid: 98e951195b090704697ae29d2305be5d, type: 2}
    text: "\u4E50\u961F\u91CC\u7684\u9633\u89D2\u4F1A\u4E3A\u4F60\u63D0\u4F9B\u989D\u5916\u7684\u9633\u5149\uFF0C\u662F\u5F88\u91CD\u8981\u7684\u5355\u4F4D\u3002\u8BF7\u79CD\u690D\u81F3\u5C11\u4E09\u682A\u8679\u590F\u6295\u5F71"
